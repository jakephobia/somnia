{
  "name": "sleepcast",
  "version": "1.0.0",
  "description": "YouTube to Sleep Audio Mixer - Estrae audio da YouTube e lo mixa con musica e suoni ambientali",
  "main": "backend/server.js",
  "scripts": {
    "prestart": "npm run build",
    "start": "node backend/server.js",
    "build": "esbuild public/js/app.js --bundle --format=esm --outdir=public/dist"
  },
  "keywords": [
    "sleep",
    "audio",
    "youtube",
    "podcast"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@soundtouchjs/audio-worklet": "^1.0.7",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "tone": "^15.1.22",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.27.4"
  }
}
